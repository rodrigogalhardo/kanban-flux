generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  avatar    String?
  isAgent   Boolean  @default(false)
  createdAt DateTime @default(now())

  workspaces    WorkspaceMember[]
  cards         CardMember[]
  comments      Comment[]
  agent         Agent?
  notifications Notification[]
  attachments   CardAttachment[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  boards   Board[]
  members  WorkspaceMember[]
  apiKeys  AgentApiKey[]
  projects Project[]
}

model WorkspaceMember {
  id          String @id @default(cuid())
  role        Role   @default(MEMBER)
  userId      String
  workspaceId String

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

model Board {
  id          String      @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  status      BoardStatus @default(ACTIVE)
  workspaceId String
  projectId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])
  columns   Column[]
}

enum BoardStatus {
  ACTIVE
  ARCHIVED
  PAUSED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  githubRepo  String?
  githubUrl   String?
  status      ProjectStatus @default(ACTIVE)
  autoTrigger Boolean       @default(true)   // auto-trigger agents when cards move columns
  budget      Float?        // max budget in USD for AI token costs
  budgetUsed  Float         @default(0)  // current spend
  workspaceId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  boards      Board[]
  graphNodes  GraphNode[]
  graphEdges  GraphEdge[]
  simulations Simulation[]
  sprints     Sprint[]
  webhooks    Webhook[]
}

model Column {
  id       String @id @default(cuid())
  title    String
  position Int
  boardId  String

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]
}

model Card {
  id          String    @id @default(cuid())
  title       String
  description String?
  position    Int
  priority    Int       @default(2)  // 0=P0 Critical, 1=P1 High, 2=P2 Medium, 3=P3 Low
  dueDate     DateTime?
  columnId    String
  riskScore   Int?                  // 0-100, auto-calculated
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  column     Column       @relation(fields: [columnId], references: [id], onDelete: Cascade)
  labels     CardLabel[]
  members    CardMember[]
  checklists Checklist[]
  comments   Comment[]
  agentRuns  AgentRun[]
  dependencies  CardDependency[] @relation("CardDependencies")
  dependedOnBy  CardDependency[] @relation("CardDependedOn")
  attachments   CardAttachment[]
  sprints    SprintCard[]
  history    CardHistory[]
}

model Label {
  id    String @id @default(cuid())
  name  String
  color String

  cards CardLabel[]
}

model CardLabel {
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id])

  @@id([cardId, labelId])
}

model CardMember {
  cardId String
  userId String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([cardId, userId])
}

model Checklist {
  id     String @id @default(cuid())
  title  String
  cardId String

  card  Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items ChecklistItem[]
}

model ChecklistItem {
  id          String  @id @default(cuid())
  text        String
  completed   Boolean @default(false)
  checklistId String

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

enum AgentStatus {
  IDLE
  WORKING
  PAUSED
  ERROR
}

enum AgentProvider {
  CLAUDE
  GEMINI
  OPENAI
  CUSTOM
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Agent {
  id            String        @id @default(cuid())
  userId        String        @unique
  provider      AgentProvider
  model         String
  role          String
  systemPrompt  String?
  capabilities  String[]
  status        AgentStatus   @default(IDLE)
  apiKeyId      String?
  maxConcurrent Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs           AgentRun[]
  apiKey         AgentApiKey?   @relation(fields: [apiKeyId], references: [id])
  approvalGates  ApprovalGate[]
  memories       AgentMemory[]
}

model AgentApiKey {
  id           String        @id @default(cuid())
  provider     AgentProvider
  encryptedKey String
  iv           String
  label        String
  workspaceId  String
  createdAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  agents    Agent[]
}

model AgentRun {
  id          String    @id @default(cuid())
  agentId     String
  cardId      String
  parentRunId String?
  status      RunStatus @default(QUEUED)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  tokenUsage  Int?
  cost        Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agent         Agent          @relation(fields: [agentId], references: [id])
  card          Card           @relation(fields: [cardId], references: [id])
  parentRun     AgentRun?      @relation("RunHierarchy", fields: [parentRunId], references: [id])
  childRuns     AgentRun[]     @relation("RunHierarchy")
  logs          AgentRunLog[]
  approvalGates ApprovalGate[]
}

model AgentRunLog {
  id        String   @id @default(cuid())
  runId     String
  level     String   @default("info")
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  cardId    String?
  boardId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Simulation {
  id           String   @id @default(cuid())
  projectId    String
  status       String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  rounds       Int      @default(10)
  currentRound Int      @default(0)
  results      Json?
  predictions  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actions SimulationAction[]
}

model SimulationAction {
  id           String   @id @default(cuid())
  simulationId String
  round        Int
  agentName    String
  agentRole    String
  actionType   String // PICK_TASK, COMPLETE_TASK, REQUEST_REVIEW, SKIP, BLOCKED
  targetCard   String?
  reasoning    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  simulation Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
}

model GraphNode {
  id        String   @id @default(cuid())
  projectId String
  name      String
  type      String
  summary   String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outEdges GraphEdge[] @relation("EdgeSource")
  inEdges  GraphEdge[] @relation("EdgeTarget")
}

model GraphEdge {
  id        String   @id @default(cuid())
  projectId String
  sourceId  String
  targetId  String
  relation  String
  weight    Float    @default(1.0)
  metadata  Json?
  createdAt DateTime @default(now())

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  GraphNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target  GraphNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model ApprovalGate {
  id          String   @id @default(cuid())
  runId       String
  agentId     String
  actionType  String              // "merge_pr", "create_pr", "move_card_to_done", "git_commit"
  status      String   @default("PENDING")  // PENDING, APPROVED, REJECTED
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?             // userId who approved/rejected

  run   AgentRun @relation(fields: [runId], references: [id])
  agent Agent   @relation(fields: [agentId], references: [id])
}

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  type      String              // "decision", "code_pattern", "lesson", "preference", "context"
  content   String              // the memory content
  source    String?             // cardId, runId, or project name that produced this memory
  relevance Float    @default(1.0)  // decays over time
  tags      String[]            // for quick filtering
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model TeamTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String              // "saas", "landing-page", "api", "mobile", "data"
  agents      Json                // array of agent configs [{role, name, provider, model, systemPrompt, capabilities}]
  isPublic    Boolean  @default(false)
  createdBy   String?
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CardAttachment {
  id        String   @id @default(cuid())
  cardId    String
  filename  String
  fileType  String              // "code", "document", "image", "diagram"
  mimeType  String
  content   String              // for text files: actual content. for binary: base64 or URL
  size      Int                 // bytes
  createdBy String              // userId
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [createdBy], references: [id])
}

model Sprint {
  id         String    @id @default(cuid())
  name       String                // "Sprint 1", "Sprint 2"
  projectId  String
  startDate  DateTime
  endDate    DateTime
  status     String    @default("PLANNING")  // PLANNING, ACTIVE, COMPLETED
  goal       String?               // sprint goal description
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards   SprintCard[]
}

model SprintCard {
  sprintId String
  cardId   String

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([sprintId, cardId])
}

model CardDependency {
  id          String @id @default(cuid())
  cardId      String
  dependsOnId String
  type        String @default("DEPENDS_ON")

  card      Card @relation("CardDependencies", fields: [cardId], references: [id], onDelete: Cascade)
  dependsOn Card @relation("CardDependedOn", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([cardId, dependsOnId])
}

model CardHistory {
  id        String   @id @default(cuid())
  cardId    String
  userId    String?
  action    String              // "created", "moved", "updated_description", "updated_title", "priority_changed", "agent_assigned", "attachment_added"
  details   String?             // human-readable change description
  metadata  Json?               // old/new values
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model BoardTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String              // "saas", "api", "landing-page", "mobile"
  columns     Json                // ["Todo", "Brainstorming", "In Progress", "QA", "Bug", "Done"]
  cardTemplates Json?             // [{title, description, labels, priority}]
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Webhook {
  id          String   @id @default(cuid())
  projectId   String
  name        String              // "Slack Notifications", "Discord Updates"
  url         String              // webhook URL
  events      String[]            // ["card_moved", "agent_completed", "comment_added", "approval_required"]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
