generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  avatar    String?
  isAgent   Boolean  @default(false)
  createdAt DateTime @default(now())

  workspaces    WorkspaceMember[]
  cards         CardMember[]
  comments      Comment[]
  agent         Agent?
  notifications Notification[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  boards   Board[]
  members  WorkspaceMember[]
  apiKeys  AgentApiKey[]
  projects Project[]
}

model WorkspaceMember {
  id          String @id @default(cuid())
  role        Role   @default(MEMBER)
  userId      String
  workspaceId String

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

model Board {
  id          String      @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  status      BoardStatus @default(ACTIVE)
  workspaceId String
  projectId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])
  columns   Column[]
}

enum BoardStatus {
  ACTIVE
  ARCHIVED
  PAUSED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  githubRepo  String?
  githubUrl   String?
  status      ProjectStatus @default(ACTIVE)
  workspaceId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  boards    Board[]
}

model Column {
  id       String @id @default(cuid())
  title    String
  position Int
  boardId  String

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]
}

model Card {
  id          String    @id @default(cuid())
  title       String
  description String?
  position    Int
  dueDate     DateTime?
  columnId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  column     Column        @relation(fields: [columnId], references: [id], onDelete: Cascade)
  labels     CardLabel[]
  members    CardMember[]
  checklists Checklist[]
  comments   Comment[]
  agentRuns  AgentRun[]
}

model Label {
  id    String @id @default(cuid())
  name  String
  color String

  cards CardLabel[]
}

model CardLabel {
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id])

  @@id([cardId, labelId])
}

model CardMember {
  cardId String
  userId String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([cardId, userId])
}

model Checklist {
  id     String @id @default(cuid())
  title  String
  cardId String

  card  Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items ChecklistItem[]
}

model ChecklistItem {
  id          String  @id @default(cuid())
  text        String
  completed   Boolean @default(false)
  checklistId String

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

enum AgentStatus {
  IDLE
  WORKING
  PAUSED
  ERROR
}

enum AgentProvider {
  CLAUDE
  GEMINI
  OPENAI
  CUSTOM
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Agent {
  id            String        @id @default(cuid())
  userId        String        @unique
  provider      AgentProvider
  model         String
  role          String
  systemPrompt  String?
  capabilities  String[]
  status        AgentStatus   @default(IDLE)
  apiKeyId      String?
  maxConcurrent Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs     AgentRun[]
  apiKey   AgentApiKey? @relation(fields: [apiKeyId], references: [id])
}

model AgentApiKey {
  id           String        @id @default(cuid())
  provider     AgentProvider
  encryptedKey String
  iv           String
  label        String
  workspaceId  String
  createdAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  agents    Agent[]
}

model AgentRun {
  id          String    @id @default(cuid())
  agentId     String
  cardId      String
  parentRunId String?
  status      RunStatus @default(QUEUED)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  tokenUsage  Int?
  cost        Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agent     Agent       @relation(fields: [agentId], references: [id])
  card      Card        @relation(fields: [cardId], references: [id])
  parentRun AgentRun?   @relation("RunHierarchy", fields: [parentRunId], references: [id])
  childRuns AgentRun[]  @relation("RunHierarchy")
  logs      AgentRunLog[]
}

model AgentRunLog {
  id        String   @id @default(cuid())
  runId     String
  level     String   @default("info")
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  cardId    String?
  boardId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
